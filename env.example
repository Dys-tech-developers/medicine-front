# =============================================================================
# medicine-front — variables de entorno (copiar a .env.local)
# =============================================================================
#
# Dos túneles ngrok en desarrollo (es normal):
#
#   Túnel A — Front (Next, puerto 3000)
#     Lo abrís en el celular. Configurar host en next.config.ts → allowedDevOrigins
#     y opcional DEV_ALLOWED_ORIGINS (sin https://).
#
#   Túnel B — Back (Express, puerto 3001)  ← ESTA variable
#     Va en NEXT_PUBLIC_API_URL abajo. No mezclar con localhost:3001 si el front
#     se abre desde el celular vía ngrok.
#
# Cada vez que reinicien ngrok del BACK, actualizar NEXT_PUBLIC_API_URL y
# reiniciar Next: npm run dev
#
# Sin barra final en la URL.
# =============================================================================

# Backend (medicine-back) — túnel ngrok del puerto 3001
NEXT_PUBLIC_API_URL=https://URL-NGROK-DEL-BACKEND.ngrok-free.app

# Local sin ngrok:
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Si exponés el FRONT por ngrok (HMR / hot reload), host sin https://:
# DEV_ALLOWED_ORIGINS=xxxx.ngrok-free.app
